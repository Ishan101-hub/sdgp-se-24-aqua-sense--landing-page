# ─────────────────────────────────────────────────────────────────
# .env.sample  —  Environment variables template
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename it to  .env
#   2. Fill in your real values below
#   3. .env is in .gitignore — it will never be committed
# ─────────────────────────────────────────────────────────────────

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address to receive feedback submissions
EMAIL_TO=your@email.com

# Allowed CORS origin (your frontend domain, or * for development)
ALLOWED_ORIGIN=*

# Port (optional — defaults to 3000)
PORT=3000
